# Application
APP_NAME=NTURUBA
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/nturuba

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nturuba_school_db
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=NTURUBA
MAIL_FROM_ADDRESS=noreply@nturuba.local

# Security
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_TYPES=pdf,doc,docx,xls,xlsx,jpg,png,jpeg

# Pagination
PAGINATION_PER_PAGE=20

# Time Zone
TIME_ZONE=Africa/Nairobi

# API
API_VERSION=v1